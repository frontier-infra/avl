{
  "name": "@frontier-infra/avl",
  "version": "0.1.0",
  "description": "Agent View Layer — producer-side rendering for AI agents",
  "license": "MIT",
  "author": "Argent OS",
  "repository": {
    "type": "git",
    "url": "https://github.com/frontier-infra/avl.git"
  },
  "keywords": [
    "ai",
    "agent",
    "view-layer",
    "producer-side",
    "toon",
    "agent-view",
    "mcp",
    "llm",
    "nextjs"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
